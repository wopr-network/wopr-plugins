{
  "dependencies": {
    "@kobalte/core": "^0.13.0",
    "@wopr-network/plugin-types": "workspace:*",
    "solid-js": "^1.9.0"
  },
  "description": "Web UI plugin for WOPR - SolidJS-based dashboard for sessions, plugins, and configuration",
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "autoprefixer": "10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.11"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "name": "@wopr-network/wopr-plugin-webui",
  "scripts": {
    "lint": "biome check src/",
    "build": "echo 'webui builds with vite, not tsc'",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "npm run build"
  },
  "type": "module",
  "version": "0.2.0",
  "wopr": {
    "minVersion": "1.0.0",
    "provides": [
      "webui"
    ],
    "type": "plugin"
  },
  "keywords": [
    "wopr-plugin",
    "wopr",
    "webui",
    "solidjs",
    "dashboard"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "dist-plugin"
  ]
}
