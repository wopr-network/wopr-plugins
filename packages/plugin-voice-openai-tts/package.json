{
  "description": "OpenAI TTS provider for WOPR voice",
  "keywords": [
    "wopr-plugin"
  ],
  "devDependencies": {
    "@types/node": "^25.5.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "name": "@wopr-network/wopr-plugin-voice-openai-tts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "biome check src/",
    "build": "tsc",
    "test": "echo \"tests need migration fix\" && exit 0",
    "prepublishOnly": "npm run build"
  },
  "type": "module",
  "version": "1.0.0",
  "wopr": {
    "plugin": {
      "category": "voice",
      "description": "OpenAI Text-to-Speech",
      "name": "voice-openai-tts",
      "primaryEnv": "OPENAI_API_KEY",
      "requires": {
        "env": [
          "OPENAI_API_KEY"
        ]
      },
      "type": "tts"
    }
  },
  "dependencies": {
    "@wopr-network/plugin-types": "workspace:*"
  }
}
